# ============================================
# YTMusic Backend — LOCAL DEVELOPMENT
# ============================================
# .env.local. Для переключения на облако:
#   cp .env.cloud .env

DEBUG=True

SECRET_KEY=local-dev-secret-key-change-in-prod
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# PostgreSQL (docker-compose service "db")
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ytmusic

# MinIO (S3-compatible, docker-compose service "minio")
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=yt-music
R2_ENDPOINT_URL=http://minio:9000
R2_PUBLIC_ENDPOINT_URL=http://localhost:9000