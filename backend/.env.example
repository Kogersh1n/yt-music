# YTMusic Backend — Environment Template
#   Для локальной разработки:  cp .env.example .env  
#   Для облака/прода:          cp .env.cloud .env

DEBUG=True

SECRET_KEY=
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
CORS_ORIGINS=["http://localhost:5173"]

# --- PostgreSQL ---
DB_HOST=db
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=ytmusic

# --- S3-compatible Storage (MinIO / Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yt-music

# Для MinIO (локалка): R2_ENDPOINT_URL=http://minio:9000
# Для R2 (облако):     закомментируй R2_ENDPOINT_URL — сформируется автоматически
R2_ENDPOINT_URL=http://minio:9000
